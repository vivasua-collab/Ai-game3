# Unity папки (НЕ выгружать!)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures нельзя восстановить
/[Mm]emoryCaptures/

# Asset meta data ДОЛЖНА быть в Git (важно для синхронизации!)
!/[Aa]ssets/**/*.meta

# Но некоторые Assets файлы игнорируем
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio / VS Code cache
.vs/
.vscode/

# Gradle cache
.gradle/

# Autogenerated solution files (генерируются Unity)
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.idea/
*.swp
*.swo
*~

# Local settings
local.properties

# Crashlytics
crashlytics-build.properties
fabric.properties

# ============================================================
# ВАЖНО ДЛЯ СИНХРОНИЗАЦИИ ДВУХ ПК:
# ============================================================
# ✅ В Git ДОЛЖНЫ быть:
#   - Assets/ (все файлы и .meta)
#   - ProjectSettings/ (настройки проекта)
#   - Packages/manifest.json (зависимости)
#
# ❌ В Git НЕ ДОЛЖНЫ быть:
#   - Library/ (кэш, генерируется Unity)
#   - Temp/ (временные файлы)
#   - Build/ (сборки)
#   - Logs/ (логи)
#
# ⚠️ ПЕРЕД ПУШЕМ:
#   1. Закрыть Unity (или подождать завершения импорта)
#   2. git pull (получить изменения)
#   3. git add -A
#   4. git commit -m "message"
#   5. git push
#
# ⚠️ ПОСЛЕ ПУЛЛА (на другом ПК):
#   1. Открыть Unity
#   2. Дождаться завершения импорта
#   3. Проверить Console на ошибки
# ============================================================
